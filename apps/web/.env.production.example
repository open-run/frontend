# apps/web/.env.production — production values behind the WEB_ENV GitHub secret.
# This example documents the KEYS only (no real values).
#
# To (re)generate the secret from a filled-in apps/web/.env.production:
#   base64 -i apps/web/.env.production | gh secret set WEB_ENV --repo open-run/frontend
#
# One file feeds TWO consumers, which constrains its format:
#   1. `next build` auto-loads it  → NEXT_PUBLIC_* are inlined into the client bundle.
#   2. `docker run --env-file`      → server-only vars reach the running container.
# docker's --env-file does NOT strip quotes and does NOT allow spaces, so:
#   - values MUST be unquoted and space-free
#   - `#` comments and blank lines are fine
#   - one KEY=VALUE per line

# --- Build-time (inlined into the client bundle; public by design) ---
NEXT_PUBLIC_API_SERVER_URL=https://api.open-run.xyz
NEXT_PUBLIC_SWARM_GATEWAY_URL=https://swarm-api.yjkellyjoo.dev
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Runtime (server-only; never inlined, never baked into the image) ---
API_SERVER_URL=http://openrun:8080
GOOGLE_API_KEY=
OPENWEATHER_API_KEY=
