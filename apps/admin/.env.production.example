# apps/admin/.env.production — production values behind the ADMIN_ENV GitHub secret.
# See apps/web/.env.production.example for the full explanation and format constraints.
#
# To (re)generate the secret:
#   base64 -i apps/admin/.env.production | gh secret set ADMIN_ENV --repo open-run/frontend

# --- Build-time (inlined into the client bundle) ---
NEXT_PUBLIC_API_SERVER_URL=https://api.open-run.xyz
NEXT_PUBLIC_SWARM_GATEWAY_URL=https://swarm-api.yjkellyjoo.dev
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Runtime (server-only) ---
API_SERVER_URL=http://openrun:8080
