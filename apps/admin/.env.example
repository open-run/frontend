# --- Client-side (NEXT_PUBLIC_* — 빌드 타임에 번들로 인라인, 브라우저에 노출) ---

# 백엔드 API 서버 URL — 브라우저의 모든 API 호출 대상.
NEXT_PUBLIC_API_SERVER_URL=https://api.open-run.xyz

# Swarm Gateway URL — NFT 카탈로그 이미지 호스트 (next/image remotePatterns 허용 목록).
# 백엔드 nft.swarm-gateway-url과 동일한 값이어야 함. 미설정 시 https://api.gateway.ethswarm.org 폴백.
NEXT_PUBLIC_SWARM_GATEWAY_URL=https://swarm-api.yjkellyjoo.dev

# Reown(WalletConnect) Project ID — 지갑 연결
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Server-side (Node 서버에서만 사용 — 브라우저에 노출되지 않음) ---

# SSR 전용 백엔드 주소 — VM 도커 내부망으로 직결 (프로덕션 전용).
# 로컬에서는 설정하지 않음. 미설정 시 SSR은 NEXT_PUBLIC_API_SERVER_URL로 폴백.
API_SERVER_URL=http://openrun:8080
